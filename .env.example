# Arbitrum Sepolia (testnet only)
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
CHAIN_ID=421614

# USDC on Arbitrum Sepolia (EIP-3009 capable)
USDC_ADDRESS=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d

# Self-hosted x402 facilitator (CDP does not cover Sepolia)
FACILITATOR_PORT=4021
FACILITATOR_PRIVATE_KEY=

# Deployed RSS contracts (filled after deploy)
ESCROW=
COVERAGE_MANAGER=
DELIVERY_DEADLINE_RESOLVER=
DELIVERY_POLICY=
X402_ESCROW_RECEIVER=

# --- Payment Agents (apps/demo/.env.local) ---

# Anthropic API key for the buying agent
ANTHROPIC_API_KEY=

# Persistence for the demo's agent + session state.
# Unset locally -> the demo uses local JSON files (.agent-store.json / .session-store.json).
# On Vercel -> add a Neon Postgres integration; it injects DATABASE_URL and the demo
# auto-creates its kv_store table on first use. POSTGRES_URL is also accepted.
DATABASE_URL=

# Escrow-gated x402 (addresses of the contracts in packages/contracts, filled after deploy)
ESCROW_ADDRESS=
X402_RECEIVER_ADDRESS=
# Confidential (FHE) settlement target — the deployed Reineira confidential stack
CONFIDENTIAL_USDC_ADDRESS=
CONFIDENTIAL_ESCROW_ADDRESS=
# Deployed by script/ConfidentialX402ReceiverDeploy.s.sol
CONFIDENTIAL_X402_RECEIVER_ADDRESS=
CONFIDENTIAL_COVERAGE_MANAGER_ADDRESS=
# Deployed by script/ConfidentialDeliveryDeploy.s.sol (binds to DELIVERY_DEADLINE_RESOLVER_ADDRESS)
CONFIDENTIAL_DELIVERY_POLICY_ADDRESS=
# Provisioned confidential underwriter pool (created by apps/demo/scripts, staked via stake-confidential-pool.mts)
CONFIDENTIAL_POOL_ADDRESS=
TIMELOCK_RESOLVER_ADDRESS=
# Seller: receives escrow releases; pays gas to open one escrow per 402 (needs a little Sepolia ETH)
SELLER_PRIVATE_KEY=
# Seconds until the TimeLock resolver lets the seller release (demo default 900 = 15 min)
ESCROW_DEADLINE_SECONDS=900

# Agent smart wallet (ZeroDev Kernel v3.1, EntryPoint 0.7). The key is the Kernel OWNER
# (gas is paymaster-sponsored; the Kernel address itself must hold testnet USDC to pay).
AGENT_PRIVATE_KEY=
# Public ZeroDev client id for your project.
ZERODEV_PROJECT_ID=

# Legacy direct-pay fallback (EOA buyer, used when AGENT_PRIVATE_KEY is unset)
BUYER_PRIVATE_KEY=
