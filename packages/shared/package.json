{
  "name": "@reineira-os/x402-shared",
  "version": "0.1.0",
  "description": "Shared types, ABIs, and chain/x402 constants for the Reineira x402 adapter.",
  "keywords": [
    "x402",
    "types",
    "abi",
    "constants",
    "arbitrum",
    "web3"
  ],
  "author": "Reineira Labs (https://reineira.xyz)",
  "homepage": "https://github.com/ReineiraOS/x402#readme",
  "bugs": "https://github.com/ReineiraOS/x402/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ReineiraOS/x402.git",
    "directory": "packages/shared"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "vitest": "^2.1.0",
    "typescript": "^5.7.0"
  }
}
