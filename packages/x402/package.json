{
  "name": "@reineira-os/x402",
  "version": "0.1.0",
  "description": "Insured, FHE-confidential x402 settlement on the Reineira Settlement Standard (umbrella SDK)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ReineiraOS/x402.git",
    "directory": "packages/x402"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "viem": "^2.21.0",
    "@reineira-os/x402-core": "workspace:*",
    "@reineira-os/x402-shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0",
    "typescript": "^5.7.0"
  }
}
