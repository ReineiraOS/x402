{
  "name": "@reineira-os/x402-core",
  "version": "0.1.1",
  "description": "x402 settlement SDK — exact (EIP-3009) scheme, escrow funding, and the Fhenix FHE codec.",
  "keywords": [
    "x402",
    "settlement",
    "escrow",
    "eip-3009",
    "fhe",
    "fhenix",
    "sdk",
    "viem"
  ],
  "author": "Reineira Labs (https://reineira.xyz)",
  "homepage": "https://github.com/ReineiraOS/x402#readme",
  "bugs": "https://github.com/ReineiraOS/x402/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ReineiraOS/x402.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./http": {
      "types": "./dist/http.d.ts",
      "import": "./dist/http.js"
    },
    "./exact/client": {
      "types": "./dist/exact/client.d.ts",
      "import": "./dist/exact/client.js"
    },
    "./exact/escrow": {
      "types": "./dist/exact/escrow.d.ts",
      "import": "./dist/exact/escrow.js"
    },
    "./exact/verify": {
      "types": "./dist/exact/verify.d.ts",
      "import": "./dist/exact/verify.js"
    },
    "./exact/settle": {
      "types": "./dist/exact/settle.d.ts",
      "import": "./dist/exact/settle.js"
    },
    "./facilitator": {
      "types": "./dist/facilitator.d.ts",
      "import": "./dist/facilitator.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "viem": "^2.21.0",
    "@reineira-os/x402-shared": "workspace:*",
    "@cofhe/sdk": "^0.5.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@x402/core": "^2.14.0",
    "@x402/evm": "^2.14.0",
    "@x402/fetch": "^2.14.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0",
    "typescript": "^5.7.0"
  }
}
